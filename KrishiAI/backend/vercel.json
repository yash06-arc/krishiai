{
    "version": 2,
    "builds": [
      {
        "src": "app.py",
        "use": "@vercel/python"
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "app.py"
      }
    ],
    "crons": [
      {
        "path": "/api/sync",
        "schedule": "0 6 * * *"
      }
    ]
  }
